# Secrets
.env
android/app/google-services.json
service-account*.json

# Android signing - NEVER commit these (10-year Play Store keystore)
android/key.properties
android/*.jks
android/*.keystore
android/app/*.jks
android/app/*.keystore
*.jks
*.keystore
key.properties

# Local config
.claude/settings.local.json

# Test creds (local-only, never commit)
test_credentials*
.claude/test_credentials*

# Junk artifacts
Get
Process
Run
flutter
flutter_log.txt

# Screenshots (dev only)
screenshots/
.tmp_screens/
screen_broken.png
screen_editprofile.png

# R-prefixed PR smoke artifacts (Rxx_smoke_*.png + Rxx_ui_dump_*.xml).
# Wildcard catches future R14, R15, ... so we don't need a new
# gitignore commit per PR. Existing commits that already shipped
# specific smoke .pngs (e.g. R11 docs(R11) UI smoke verification)
# are not retroactively affected — git tracks them once they're in.
.claude/r*_smoke_*.png
.claude/r*_ui_dump_*.xml

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
/coverage/

# Supabase temp
supabase/.temp/

# Noblara nested project (if unused)
noblara_flutter/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
