# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Provider (optional - mock provider used if not set)
AI_PROVIDER=mock
# For OpenAI:
# AI_PROVIDER=openai
# OPENAI_API_KEY=your-openai-key
# For Anthropic:
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-key

# Instagram OAuth (placeholder - manual verification used if not set)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=

# RevenueCat (placeholder)
REVENUECAT_API_KEY=
REVENUECAT_PUBLIC_KEY=

# Sentry (placeholder)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# App Configuration
APP_ENV=development
API_BASE_URL=http://localhost:54321

# Admin Configuration
ADMIN_EMAILS=admin@noblara.app

# Feature Flags
ENABLE_BOOTSTRAP_MODE=true
ENABLE_MALE_COUNTER_PROPOSAL=false
REQUIRE_VIDEO_CALL=true
